# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Google Gemini API key — used by the /api/chat route (AI chatbot feature, future task).
GOOGLE_GENERATIVE_AI_API_KEY=

# Canonical site URL — used to build absolute Open Graph and Twitter card URLs.
# Example: https://oscar.dev
NEXT_PUBLIC_SITE_URL=https://portfolio.local
